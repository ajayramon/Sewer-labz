generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Company {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now()) @map("created_at")
  users        User[]
  subscription Subscription?
  templates    Template[]
  @@map("companies")
}
model User {
  id               String            @id @default(uuid())
  companyId        String?           @map("company_id")
  firebaseUid      String            @unique @map("firebase_uid")
  email            String            @unique
  name             String?
  role             UserRole          @default(MEMBER)
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  company          Company?          @relation(fields: [companyId], references: [id])
  reports          Report[]
  templates        Template[]
  termsAcceptances TermsAcceptance[]
  @@index([companyId])
  @@index([firebaseUid])
  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
  GOD
}

model TermsAcceptance {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  termsVersion String   @map("terms_version")
  ipAddress    String?  @map("ip_address")
  acceptedAt   DateTime @default(now()) @map("accepted_at")
  user         User     @relation(fields: [userId], references: [id])
  @@map("terms_acceptances")
}

model Subscription {
  id               String             @id @default(uuid())
  companyId        String             @unique @map("company_id")
  plan             PlanType
  status           SubscriptionStatus
  trialStartDate   DateTime?          @map("trial_start_date")
  trialEndsAt      DateTime?          @map("trial_ends_at")
  currentPeriodEnd DateTime?          @map("current_period_end")
  stripeCustomerId String?            @map("stripe_customer_id")
  stripeSubId      String?            @map("stripe_sub_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  company          Company            @relation(fields: [companyId], references: [id])
  @@map("subscriptions")
}
enum PlanType {
  TRIAL
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Report {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  title       String
  jobNumber   String?      @map("job_number")
  clientName  String?      @map("client_name")
  location    String?
  inspectedAt DateTime?    @map("inspected_at")
  status      ReportStatus @default(DRAFT)
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  user        User         @relation(fields: [userId], references: [id])
  defects     Defect[]
  @@index([userId])
  @@index([status])
  @@map("reports")
}

enum ReportStatus {
  DRAFT
  COMPLETE
  ARCHIVED
}

model Defect {
  id          String        @id @default(uuid())
  reportId    String        @map("report_id")
  code        String
  description String
  narrative   String?       @db.Text
  severity    String?
  position    Int
  createdAt   DateTime      @default(now()) @map("created_at")
  report      Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  images      DefectImage[]
  @@index([reportId])
  @@map("defects")
}

model DefectImage {
  id        String   @id @default(uuid())
  defectId  String   @map("defect_id")
  url       String
  publicId  String   @map("public_id")
  width     Int?
  height    Int?
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  defect    Defect   @relation(fields: [defectId], references: [id], onDelete: Cascade)
  @@index([defectId])
  @@map("defect_images")
}

model Template {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  companyId   String?  @map("company_id")
  name        String
  description String?
  structure   Json
  isShared    Boolean  @default(false) @map("is_shared")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id])
  @@index([userId])
  @@index([companyId])
  @@map("templates")
}

model SupportRequest {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("open")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("support_requests")
}